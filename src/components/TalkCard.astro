---
interface Props {
  title: string;
  date?: Date;
  event: string;
  tag?: string;
  links?: {
    slides?: string;
    web?: string;
    video?: string;
    report?: string;
    press?: string;
  };
  thumbnail?: string;
  compact?: boolean;
}

const { title, date, event, tag, links, thumbnail, compact = false } = Astro.props;

const dateStr = date
  ? new Intl.DateTimeFormat('ja-JP', { year: 'numeric', month: 'long' }).format(date)
  : '';

// Color presets per known tag. Unknown tags fall back to neutral.
// Add new entries as new tag values appear in content frontmatter.
const tagColors: Record<string, string> = {
  '講演': 'bg-sky-50 text-sky-800 border-sky-200',
  'メディア': 'bg-amber-50 text-amber-800 border-amber-200',
  '表彰': 'bg-rose-50 text-rose-800 border-rose-200',
};
const badgeColor = tag ? tagColors[tag] ?? 'bg-gray-50 text-gray-700 border-gray-200' : '';
---

<article class={`group relative border border-gray-200 rounded-lg overflow-hidden bg-white hover:border-gray-400 hover:shadow-md hover:-translate-y-0.5 transition-[transform,box-shadow,border-color] duration-200 ${compact ? '' : ''}`}>
  {tag && (
    <span class={`absolute top-2 right-2 z-10 inline-block text-[10px] tracking-wide font-medium px-2 py-0.5 rounded-full border ${badgeColor}`}>
      {tag}
    </span>
  )}
  {thumbnail && (
    <div class="aspect-video bg-gray-100 overflow-hidden">
      <img src={thumbnail} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
    </div>
  )}
  <div class="p-4">
    {dateStr && <p class="text-xs text-gray-500 mb-1.5">{dateStr}</p>}
    <h3 class="text-base font-medium leading-snug text-gray-900 mb-2 group-hover:text-sky-800 transition-colors">{title}</h3>
    <p class="text-sm text-gray-600 leading-relaxed">{event}</p>
    {links && (
      <div class="flex gap-3 mt-3 text-xs">
        {links.web && <a href={links.web} target="_blank" rel="noopener" class="text-blue-700 hover:underline">Web</a>}
        {links.press && <a href={links.press} target="_blank" rel="noopener" class="text-blue-700 hover:underline">Press</a>}
        {links.slides && <a href={links.slides} target="_blank" rel="noopener" class="text-blue-700 hover:underline">Slides</a>}
        {links.video && <a href={links.video} target="_blank" rel="noopener" class="text-blue-700 hover:underline">Video</a>}
        {links.report && <a href={links.report} target="_blank" rel="noopener" class="text-blue-700 hover:underline">Report</a>}
      </div>
    )}
  </div>
</article>
