---
import type { PublicationTag } from '../utils/publication-tag';

interface Props {
  title: string;
  date: Date;
  venue: string;
  authors: string;
  tag: PublicationTag;
  thumbnail?: string;
  links?: {
    paper?: string;
    slides?: string;
    web?: string;
  };
}

const { title, date, venue, authors, tag, thumbnail, links } = Astro.props;
const year = date.getFullYear();

const tagColor = tag === 'パテント'
  ? 'bg-violet-50 text-violet-800 border-violet-200'
  : 'bg-emerald-50 text-emerald-800 border-emerald-200';

// What to call the paper link badge based on the URL it points at.
// Linking the title itself was misleading (most URLs go to a landing
// page, not the paper PDF), so the link lives in this badge instead.
function paperBadgeLabel(url: string): string {
  if (url.includes('patents.google.com')) return 'Google Patent';
  if (/^https?:\/\/arxiv\.org\//.test(url)) return 'arXiv';
  if (/\.pdf(\?|#|$)/i.test(url)) return 'PDF';
  return 'Paper';
}

const hasAnyLink = !!(links?.paper || links?.web || links?.slides);
---

<li class="py-3 border-b border-gray-100 last:border-0" data-tag={tag}>
  <div class="flex gap-4 items-start">
    <div class="flex-1 min-w-0">
      <p class="text-base text-gray-900 leading-snug">{title}</p>
      <p class="text-sm text-gray-600 mt-1">{authors}</p>
      <p class="text-sm text-gray-500 mt-0.5">
        <em class="not-italic">{venue}</em>, {year}
      </p>
      {hasAnyLink && (
        <div class="flex gap-3 mt-1 text-xs">
          {links?.paper && (
            <a href={links.paper} target="_blank" rel="noopener" class="text-blue-700 hover:underline">
              {paperBadgeLabel(links.paper)}
            </a>
          )}
          {links?.web && <a href={links.web} target="_blank" rel="noopener" class="text-blue-700 hover:underline">Web</a>}
          {links?.slides && <a href={links.slides} target="_blank" rel="noopener" class="text-blue-700 hover:underline">Slides</a>}
        </div>
      )}
    </div>
    <div class="shrink-0 flex flex-col items-end gap-1.5 w-28">
      <span class={`text-[10px] tracking-wide font-medium px-2 py-0.5 rounded-full border ${tagColor}`}>
        {tag}
      </span>
      {thumbnail && (
        <a
          href={links?.paper ?? links?.web}
          target="_blank"
          rel="noopener"
          class="block w-full aspect-[16/9] bg-white border border-gray-200 rounded overflow-hidden"
          aria-label="サムネイル"
        >
          <img src={thumbnail} alt="" class="w-full h-full object-contain" />
        </a>
      )}
    </div>
  </div>
</li>
