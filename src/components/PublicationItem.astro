---
interface Props {
  title: string;
  date: Date;
  venue: string;
  authors: string;
  links?: {
    paper?: string;
    slides?: string;
    web?: string;
  };
}

const { title, date, venue, authors, links } = Astro.props;
const year = date.getFullYear();
---

<li class="py-3 border-b border-gray-100 last:border-0">
  <p class="text-base text-gray-900 leading-snug">
    {links?.paper ? (
      <a href={links.paper} target="_blank" rel="noopener" class="hover:underline">{title}</a>
    ) : (
      <span>{title}</span>
    )}
  </p>
  <p class="text-sm text-gray-600 mt-1">{authors}</p>
  <p class="text-sm text-gray-500 mt-0.5">
    <em class="not-italic">{venue}</em>, {year}
  </p>
  {links && (links.web || links.slides) && (
    <div class="flex gap-3 mt-1 text-xs">
      {links.web && <a href={links.web} target="_blank" rel="noopener" class="text-blue-700 hover:underline">Web</a>}
      {links.slides && <a href={links.slides} target="_blank" rel="noopener" class="text-blue-700 hover:underline">Slides</a>}
    </div>
  )}
</li>
