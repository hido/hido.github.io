---
import type { PublicationTag } from '../utils/publication-tag';

interface Props {
  title: string;
  date: Date;
  venue: string;
  authors: string;
  tag: PublicationTag;
  thumbnail?: string;
  links?: {
    paper?: string;
    slides?: string;
    web?: string;
  };
}

const { title, date, venue, authors, tag, thumbnail, links } = Astro.props;
const year = date.getFullYear();

const tagColor = tag === 'パテント'
  ? 'bg-violet-50 text-violet-800 border-violet-200'
  : 'bg-emerald-50 text-emerald-800 border-emerald-200';

// What to call the paper link badge based on the URL it points at.
// Linking the title itself was misleading (most URLs go to a landing
// page, not the paper PDF), so the link lives in this badge instead.
function paperBadgeLabel(url: string): string {
  if (url.includes('patents.google.com')) return 'Google Patent';
  if (/^https?:\/\/arxiv\.org\//.test(url)) return 'arXiv';
  if (/\.pdf(\?|#|$)/i.test(url)) return 'PDF';
  return 'Paper';
}

const hasAnyLink = !!(links?.paper || links?.web || links?.slides);
const primaryLink = links?.paper ?? links?.web ?? links?.slides;

// Outlined-button styling shared by every link badge.
const btnClass =
  'inline-flex items-center px-2.5 py-1 text-xs font-medium border border-gray-300 rounded-md text-gray-700 no-underline hover:no-underline hover:bg-gray-50 hover:border-gray-500 hover:text-gray-900 transition-colors';
---

<li class="relative flex gap-4 py-3 border-b border-gray-100 last:border-0 pr-20" data-tag={tag}>
  {thumbnail ? (
    <a
      href={primaryLink}
      target="_blank"
      rel="noopener"
      class="shrink-0 self-stretch block w-40 bg-white border border-gray-200 rounded overflow-hidden"
      aria-label="サムネイル"
    >
      <img src={thumbnail} alt="" class="w-full h-full object-contain" />
    </a>
  ) : (
    <div class="shrink-0 self-stretch w-40 bg-gray-50 border border-dashed border-gray-200 rounded" aria-hidden="true"></div>
  )}

  <div class="flex-1 min-w-0">
    <p class="text-base text-gray-900 leading-snug">{title}</p>
    <p class="text-sm text-gray-600 mt-1">{authors}</p>
    <p class="text-sm text-gray-500 mt-0.5">
      <em class="not-italic">{venue}</em>, {year}
    </p>
    {hasAnyLink && (
      <div class="flex flex-wrap gap-2 mt-2">
        {links?.paper && (
          <a href={links.paper} target="_blank" rel="noopener" class={btnClass}>
            {paperBadgeLabel(links.paper)}
          </a>
        )}
        {links?.web && <a href={links.web} target="_blank" rel="noopener" class={btnClass}>Web</a>}
        {links?.slides && <a href={links.slides} target="_blank" rel="noopener" class={btnClass}>Slides</a>}
      </div>
    )}
  </div>

  <span class={`absolute top-3 right-0 text-[10px] tracking-wide font-medium px-2 py-0.5 rounded-full border ${tagColor}`}>
    {tag}
  </span>
</li>
