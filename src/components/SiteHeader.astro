---
const { pathname } = Astro.url;
const navItems = [
  { href: '/', label: 'Top' },
  { href: '/talks-and-media/', label: '講演/メディア' },
  { href: '/publications/', label: '論文' },
  { href: '/blog/', label: 'Blog' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname === href || pathname === href.replace(/\/$/, '');
}

function navLinkClass(href: string) {
  return [
    'no-underline hover:no-underline transition-colors',
    isActive(href)
      ? 'text-gray-900 font-medium md:border-b-2 md:border-gray-900 md:pb-0.5'
      : 'text-gray-600 hover:text-gray-900',
  ].join(' ');
}
---

<header class="border-b border-gray-200 bg-white/90 backdrop-blur sticky top-0 z-20">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="font-medium text-lg tracking-wide text-gray-900 no-underline hover:no-underline shrink-0">
      比戸 将平 <span class="text-gray-400 font-normal">— Shohei Hido</span>
    </a>

    {/* Desktop nav */}
    <nav class="hidden md:flex gap-5 text-sm">
      {navItems.map((item) => (
        <a href={item.href} class={navLinkClass(item.href)}>{item.label}</a>
      ))}
    </nav>

    {/* Mobile nav: hamburger via <details> — no JS, accessible, keyboard-friendly */}
    <details class="md:hidden relative site-nav-mobile">
      <summary
        aria-label="メニューを開く"
        class="list-none cursor-pointer text-gray-700 hover:text-gray-900 p-1 -mr-1"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 block hamburger-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden hamburger-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </summary>
      <nav class="absolute right-0 mt-2 w-48 bg-white border border-gray-200 rounded-lg shadow-md py-2 flex flex-col text-sm">
        {navItems.map((item) => (
          <a href={item.href} class={`px-4 py-2 ${navLinkClass(item.href)}`}>{item.label}</a>
        ))}
      </nav>
    </details>
  </div>
</header>

<style>
  /* Toggle hamburger ↔ close icons based on <details> open state */
  details.site-nav-mobile[open] .hamburger-open { display: none; }
  details.site-nav-mobile[open] .hamburger-close { display: block; }
  /* Hide default disclosure marker */
  details.site-nav-mobile summary::-webkit-details-marker { display: none; }
</style>
