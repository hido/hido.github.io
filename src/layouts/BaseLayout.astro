---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title?: string;
  description?: string;
  width?: 'narrow' | 'wide';
  ogImage?: string;     // override the default per-path picker
}

const {
  title = '比戸 将平 — Shohei Hido',
  description = 'Shohei Hido — ダイキン工業 テクノロジー・イノベーションセンター 技師長',
  width = 'wide',
  ogImage,
} = Astro.props;

const mainClass =
  width === 'wide'
    ? 'max-w-6xl mx-auto px-6 py-10'
    : 'max-w-3xl mx-auto px-6 py-10';

// Pick a per-path OG image; fall back to default. Pre-generated by
// scripts/generate-og.mjs into public/og/*.png.
function pickOgImage(pathname: string): string {
  const p = pathname.replace(/\/$/, '');
  if (p === '' || p === '/') return '/og/default.png';
  if (p.startsWith('/talks-and-media')) return '/og/talks-and-media.png';
  if (p.startsWith('/publications')) return '/og/publications.png';
  if (p.startsWith('/blog')) return '/og/blog.png';
  return '/og/default.png';
}

const ogPath = ogImage ?? pickOgImage(Astro.url.pathname);
const ogImageAbsolute = new URL(ogPath, Astro.site ?? 'https://hido.github.io').href;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://hido.github.io').href;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E🌅%3C/text%3E%3C/svg%3E" />
    <title>{title}</title>
  </head>
  <body class="text-gray-900 bg-white">
    <SiteHeader />
    <main class={mainClass}>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
