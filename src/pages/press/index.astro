---
import BaseLayout from '../../layouts/BaseLayout.astro';

const items: { title: string; outlet: string; url: string; date?: string }[] = [
  {
    date: '2026-03',
    outlet: '日経BP',
    title: 'AIリーダーズ100 選出',
    url: 'https://business.nikkei.com/feature/aileader/participants/',
  },
  {
    date: '2025-05-26',
    outlet: '日経クロステック',
    title: '事業会社こそがAIの利益を享受とダイキンの比戸将平氏、設計開発への活用に着手',
    url: 'https://xtech.nikkei.com/atcl/nxt/column/18/03076/052200009/',
  },
  {
    date: '2025-03',
    outlet: '日本経済新聞（本紙）',
    title: 'AI、内製化の波来る — 元プリファードのダイキン・比戸さん',
    url: 'https://www.nikkei.com/article/DGXZQOUF186OJ0Y5A310C2000000/',
  },
  {
    outlet: '東洋経済オンライン',
    title: 'AIの本格実装に見いだす日本の製造業の勝ち筋',
    url: 'https://toyokeizai.net/articles/-/860345',
  },
  {
    outlet: 'JBpress',
    title: 'ダイキンに来たAIトップランナーが若手AI人材に繰り返し伝える意外な心得',
    url: 'https://jbpress.ismedia.jp/articles/-/77907',
  },
  {
    outlet: '一般社団法人未踏 CREATORS',
    title: 'インタビュー：比戸 将平',
    url: 'https://www.mitou.org/creators/hido_shohei.html',
  },
];

function formatDate(s?: string) {
  if (!s) return '';
  const [y, m] = s.split('-');
  if (!m) return `${y}年`;
  return `${y}年${parseInt(m, 10)}月`;
}
---

<BaseLayout title="メディア掲載 — 比戸 将平">
  <h1 class="text-2xl font-medium mb-2">メディア掲載</h1>
  <p class="text-sm text-gray-500 mb-8">新聞・専門メディアによる記事・インタビュー。</p>

  <ul class="border-t border-gray-100 max-w-4xl">
    {items.map((it) => (
      <li class="py-3 border-b border-gray-100">
        <p class="text-base text-gray-900 leading-snug">
          <a href={it.url} target="_blank" rel="noopener">{it.title}</a>
        </p>
        <p class="text-xs text-gray-500 mt-1">
          {it.outlet}{it.date ? ` · ${formatDate(it.date)}` : ''}
        </p>
      </li>
    ))}
  </ul>
</BaseLayout>
