---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PublicationItem from '../../components/PublicationItem.astro';
import YearHeading from '../../components/YearHeading.astro';

const all = await getCollection('publications');
const sorted = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const grouped = new Map<string, typeof sorted>();
for (const p of sorted) {
  const y = p.data.date.getFullYear();
  const key = y >= 2023 ? String(y) : 'archive';
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(p);
}

const orderedKeys = Array.from(grouped.keys()).sort((a, b) => {
  if (a === 'archive') return 1;
  if (b === 'archive') return -1;
  return Number(b) - Number(a);
});
---

<BaseLayout title="論文 — 比戸 将平">
  <h1 class="text-2xl font-medium mb-2">論文</h1>
  <p class="text-sm text-gray-500 mb-8">論文誌・国際会議発表・特許など。</p>

  {orderedKeys.map((key) => (
    <section class="mb-10">
      <YearHeading yearKey={key} count={grouped.get(key)!.length} />
      <ul>
        {grouped.get(key)!.map((p) => (
          <PublicationItem
            title={p.data.title}
            date={p.data.date}
            venue={p.data.venue}
            authors={p.data.authors}
            links={p.data.links}
          />
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>
