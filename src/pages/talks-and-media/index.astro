---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TalkCard from '../../components/TalkCard.astro';
import YearHeading from '../../components/YearHeading.astro';

type Item = {
  id: string;
  title: string;
  date?: Date;
  subtitle: string;
  tag: string;
  links?: {
    slides?: string;
    web?: string;
    video?: string;
    report?: string;
    press?: string;
  };
  thumbnail?: string;
};

const talks = await getCollection('talks');
const press = await getCollection('press');
const awards = await getCollection('awards');

const items: Item[] = [
  ...talks.map((t) => ({
    id: t.id,
    title: t.data.title,
    date: t.data.date,
    subtitle: t.data.event,
    tag: t.data.tag,
    links: t.data.links,
    thumbnail: t.data.thumbnail,
  })),
  ...press.map((p) => ({
    id: p.id,
    title: p.data.title,
    date: p.data.date,
    subtitle: p.data.outlet,
    tag: p.data.tag,
    links: { web: p.data.url },
  })),
  ...awards.map((a) => ({
    id: a.id,
    title: a.data.title,
    date: a.data.date,
    subtitle: a.data.award,
    tag: a.data.tag,
    links: a.data.links,
  })),
];

// Sort by date desc; undated items go to the end.
items.sort((a, b) => {
  const at = a.date ? a.date.getTime() : -Infinity;
  const bt = b.date ? b.date.getTime() : -Infinity;
  return bt - at;
});

// Group by year (>=2023) or 'archive' (older or undated).
const grouped = new Map<string, Item[]>();
for (const it of items) {
  const y = it.date?.getFullYear();
  const key = y && y >= 2023 ? String(y) : 'archive';
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(it);
}

const orderedKeys = Array.from(grouped.keys()).sort((a, b) => {
  if (a === 'archive') return 1;
  if (b === 'archive') return -1;
  return Number(b) - Number(a);
});

// Distinct tags for filter UI; keep stable order with talks first.
const allTags = Array.from(new Set(items.map((it) => it.tag)));
---

<BaseLayout title="講演・メディア掲載 — 比戸 将平">
  <h1 class="text-2xl font-medium mb-2">講演・メディア掲載</h1>
  <p class="text-sm text-gray-500 mb-6">登壇イベントと、新聞・専門メディアによる記事・インタビュー。</p>

  <div class="flex flex-wrap gap-2 mb-8" role="group" aria-label="タグでフィルタ" id="tag-filter">
    <button
      type="button"
      data-filter="all"
      class="filter-btn is-active px-3 py-1 text-xs rounded-full border border-gray-300 text-gray-700 hover:border-gray-500 transition-colors"
    >
      すべて <span class="text-gray-400 ml-1" data-count="all">{items.length}</span>
    </button>
    {allTags.map((t) => (
      <button
        type="button"
        data-filter={t}
        class="filter-btn px-3 py-1 text-xs rounded-full border border-gray-300 text-gray-700 hover:border-gray-500 transition-colors"
      >
        {t} <span class="text-gray-400 ml-1" data-count={t}>{items.filter((it) => it.tag === t).length}</span>
      </button>
    ))}
  </div>

  {orderedKeys.map((key) => (
    <section class="mb-12" data-year-section={key}>
      <YearHeading yearKey={key} count={grouped.get(key)!.length} />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {grouped.get(key)!.map((it) => (
          <TalkCard
            title={it.title}
            date={it.date}
            event={it.subtitle}
            tag={it.tag}
            links={it.links}
            thumbnail={it.thumbnail}
          />
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .filter-btn.is-active {
    background-color: rgb(17 24 39); /* gray-900 */
    color: white;
    border-color: rgb(17 24 39);
  }
  .filter-btn.is-active span[data-count] {
    color: rgb(156 163 175); /* gray-400 stays subtle on dark bg */
  }
</style>

<script>
  // Tag filter for /talks-and-media/.
  // Reads ?tag= from URL on load, syncs button state, and toggles
  // visibility on cards by their data-tag attribute. Sections with
  // zero visible cards collapse so empty year headings don't dangle.
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('#tag-filter .filter-btn'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('article[data-tag]'));
  const sections = Array.from(document.querySelectorAll<HTMLElement>('section[data-year-section]'));

  function applyFilter(filter: string) {
    for (const card of cards) {
      const tag = card.dataset.tag ?? '';
      const show = filter === 'all' || tag === filter;
      card.style.display = show ? '' : 'none';
    }
    for (const section of sections) {
      const visible = section.querySelectorAll('article[data-tag]:not([style*="display: none"])').length;
      section.style.display = visible === 0 ? 'none' : '';
    }
    for (const btn of buttons) {
      btn.classList.toggle('is-active', btn.dataset.filter === filter);
    }
    const url = new URL(window.location.href);
    if (filter === 'all') url.searchParams.delete('tag');
    else url.searchParams.set('tag', filter);
    history.replaceState(null, '', url.toString());
  }

  for (const btn of buttons) {
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all'));
  }

  // Initial state from URL ?tag=...
  const initial = new URL(window.location.href).searchParams.get('tag') ?? 'all';
  if (buttons.some((b) => b.dataset.filter === initial)) {
    applyFilter(initial);
  }
</script>
