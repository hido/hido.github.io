---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TalkCard from '../components/TalkCard.astro';
import PublicationItem from '../components/PublicationItem.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { mergeContentItems } from '../utils/content-items';
import { publicationTag } from '../utils/publication-tag';

const [allTalks, allPress, allAwards] = await Promise.all([
  getCollection('talks'),
  getCollection('press'),
  getCollection('awards'),
]);
const recentTopItems = mergeContentItems(allTalks, allPress, allAwards).slice(0, 8);

const allPublications = await getCollection('publications');
const recentPublications = allPublications
  .filter((p) => publicationTag(p.data.venue) === '論文')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);
---

<BaseLayout>
  <section class="mb-16">
    <div class="flex flex-col md:flex-row gap-8 md:gap-10 items-start">
      <img
        src="/images/prof_pic.jpg"
        alt="比戸 将平"
        class="w-36 h-36 md:w-44 md:h-44 rounded-full object-cover border border-gray-200 shrink-0 mx-auto md:mx-0"
      />
      <div class="flex-1 min-w-0">
        <h1 class="text-2xl font-medium mb-2">比戸 将平 <span class="text-gray-500 font-normal ml-2">Shohei Hido</span></h1>
        <p class="text-base md:text-lg text-gray-700 mb-4">
          <a href="https://www.daikin.co.jp/" target="_blank" rel="noopener">ダイキン工業株式会社</a> テクノロジー・イノベーションセンター 技師長（DX推進担当）
        </p>
        <SocialLinks class="mb-4" />
        <p class="hero-lead">
          <span class="hero-lead-num">20年</span>にわたって、<em class="hero-lead-em">先端AI技術の産業応用</em>をリード。
        </p>
        <div class="space-y-3 text-sm leading-[1.85] text-gray-800">
          <p>
            現在、ダイキン工業株式会社 テクノロジー・イノベーションセンター（TIC）技師長として、生成AIをはじめとする先端AI技術の製造業応用、
            および全社的なデジタル変革・データ活用の推進、デジタル人材教育に従事。直近では設計開発生成AIと空調分野に特化したLLMの構築プロジェクトを牽引。
          </p>
          <p>
            2006年京都大学大学院情報学研究科修士修了（システム科学専攻）。同年日本IBM東京基礎研究所に入社し、機械学習技術の研究開発と顧客向けデータサイエンスプロジェクトに従事。
            2012年に株式会社Preferred Infrastructureへ入社。
            2014年に設立された株式会社Preferred Networksに転籍し、2015年から米シリコンバレーへChief Research Officerとして出向。
            2018年に本社帰任後は研究開発担当VP、執行役員兼インダストリーソリューション担当VPとして先端研究・大企業との共同研究開発・新規事業立ち上げを牽引。
            2023年1月より現職。
          </p>
          <p>
            研究領域は時系列解析・異常検知・密度比推定・グラフマイニングなど。
            Chainer / CuPy / Jubatus などオープンソース機械学習フレームワークのプロジェクトにも貢献。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-16">
    <div class="section-head">
      <h2 class="section-title">最近の活動 <span class="section-en">Recent activity</span></h2>
      <a class="section-cta" href="/talks-and-media/">
        もっと見る
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="13 6 19 12 13 18"></polyline>
        </svg>
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {recentTopItems.map((it) => (
        <TalkCard
          title={it.title}
          date={it.date}
          event={it.subtitle}
          eventDetail={it.subtitleDetail}
          tag={it.tag}
          links={it.links}
          thumbnail={it.thumbnail}
          copyright={it.copyright}
        />
      ))}
    </div>
  </section>

  <section class="mb-16">
    <div class="section-head">
      <h2 class="section-title">最近の論文 <span class="section-en">Publications</span></h2>
      <a class="section-cta" href="/publications/">
        もっと見る
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="13 6 19 12 13 18"></polyline>
        </svg>
      </a>
    </div>
    <ul class="border-t border-gray-100">
      {recentPublications.map((p) => (
        <PublicationItem
          title={p.data.title}
          date={p.data.date}
          venue={p.data.venue}
          authors={p.data.authors}
          tag="論文"
          thumbnail={p.data.thumbnail}
          links={p.data.links}
        />
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  /* Hero lead — editorial pull-quote with gradient bar + gradient-text accent. */
  .hero-lead {
    position: relative;
    max-width: 560px;
    margin: 0 0 1.25rem;
    padding: 12px 18px 12px 22px;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.7;
    letter-spacing: 0.01em;
    color: #0f172a;
    background: linear-gradient(180deg, #f0f9ff 0%, #fafaf9 100%);
    border-radius: 4px 10px 10px 4px;
    overflow: hidden;
  }
  .hero-lead::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, #0ea5e9 0%, #1e3a8a 100%);
    border-radius: 4px;
  }
  .hero-lead-num {
    font-weight: 700;
    background: linear-gradient(135deg, #1e3a8a 0%, #0ea5e9 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    letter-spacing: 0;
  }
  .hero-lead-em {
    font-style: normal;
    color: #1e3a8a;
    font-weight: 600;
  }

  /* Section heading — JP title + uppercase EN sub + bottom rule + pill CTA. */
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid #e2e8f0;
  }
  .section-title {
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: #0f172a;
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .section-en {
    font-family: "Inter", ui-sans-serif, sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: #94a3b8;
    text-transform: uppercase;
    transform: translateY(-2px);
  }
  .section-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    color: #0f172a;
    text-decoration: none;
    padding: 7px 12px 7px 14px;
    border: 1px solid #e2e8f0;
    border-radius: 9999px;
    background: #fff;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .section-cta:hover {
    border-color: #0f172a;
    background: #0f172a;
    color: #fff;
    text-decoration: none;
  }
  .section-cta svg {
    width: 14px;
    height: 14px;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .section-cta:hover svg {
    transform: translateX(3px);
  }
</style>
