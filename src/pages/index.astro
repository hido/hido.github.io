---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TalkCard from '../components/TalkCard.astro';
import PublicationItem from '../components/PublicationItem.astro';

const allTalks = await getCollection('talks');
const recentTalks = allTalks
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const allPublications = await getCollection('publications');
const recentPublications = allPublications
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<BaseLayout>
  <section class="mb-16">
    <div class="flex flex-col md:flex-row gap-8 md:gap-10 items-start">
      <img
        src="/images/prof_pic.jpg"
        alt="比戸 将平"
        class="w-36 h-36 md:w-44 md:h-44 rounded-full object-cover border border-gray-200 shrink-0 mx-auto md:mx-0"
      />
      <div class="flex-1 min-w-0">
        <h1 class="text-2xl font-medium mb-1">比戸 将平 <span class="text-sm text-gray-500 font-normal ml-2">Shohei Hido</span></h1>
        <p class="text-sm text-gray-600 mb-5">
          <a href="https://www.daikin.co.jp/" target="_blank" rel="noopener">ダイキン工業株式会社</a> テクノロジー・イノベーションセンター 技師長（2023年1月〜）
        </p>
        <div class="space-y-3 text-sm leading-[1.85] text-gray-800">
          <p>
            2023年1月よりダイキン工業株式会社 テクノロジー・イノベーションセンター（TIC）技師長として、AI・機械学習技術の研究開発と空調・化学事業をはじめとする産業応用、
            および全社的なデジタル変革・データ活用の推進に従事。直近では空調分野に特化したLLMの構築プロジェクトを牽引。
          </p>
          <p>
            2006年京都大学大学院情報学研究科修士修了。日本IBM東京基礎研究所で機械学習・データ解析技術の研究開発に従事した後、
            2012年に株式会社Preferred Infrastructureへ入社。2015年に米国子会社Preferred Networks AmericaのChief Research Officerに就任、
            2018年に本社帰任後は執行役員（研究開発担当VP、インダストリーソリューション担当VP）として事業開発・大企業との共同研究開発・新規事業立ち上げを牽引。
          </p>
          <p>
            研究領域は機械学習・異常検知・密度比推定・グラフマイニングなど。Chainer / CuPy / Jubatus などオープンソース機械学習フレームワークの開発にも貢献。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-16">
    <div class="flex items-baseline justify-between mb-5">
      <h2 class="text-xl font-medium">最近の講演</h2>
      <a href="/talks/" class="text-sm">すべて見る →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {recentTalks.map((talk) => (
        <TalkCard
          title={talk.data.title}
          date={talk.data.date}
          event={talk.data.event}
          links={talk.data.links}
          thumbnail={talk.data.thumbnail}
        />
      ))}
    </div>
  </section>

  <section class="mb-16">
    <div class="flex items-baseline justify-between mb-5">
      <h2 class="text-xl font-medium">最近の論文</h2>
      <a href="/publications/" class="text-sm">すべて見る →</a>
    </div>
    <ul class="border-t border-gray-100 max-w-4xl">
      {recentPublications.map((p) => (
        <PublicationItem
          title={p.data.title}
          date={p.data.date}
          venue={p.data.venue}
          authors={p.data.authors}
          links={p.data.links}
        />
      ))}
    </ul>
  </section>
</BaseLayout>
