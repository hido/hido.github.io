---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TalkCard from '../components/TalkCard.astro';
import PublicationItem from '../components/PublicationItem.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { mergeContentItems } from '../utils/content-items';
import { publicationTag } from '../utils/publication-tag';

const [allTalks, allPress, allAwards] = await Promise.all([
  getCollection('talks'),
  getCollection('press'),
  getCollection('awards'),
]);
const recentTopItems = mergeContentItems(allTalks, allPress, allAwards).slice(0, 8);

const allPublications = await getCollection('publications');
const recentPublications = allPublications
  .filter((p) => publicationTag(p.data.venue) === '論文')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);
---

<BaseLayout>
  <section class="mb-16">
    <div class="flex flex-col md:flex-row gap-8 md:gap-10 items-start">
      <img
        src="/images/prof_pic.jpg"
        alt="比戸 将平"
        class="w-36 h-36 md:w-44 md:h-44 rounded-full object-cover border border-gray-200 shrink-0 mx-auto md:mx-0"
      />
      <div class="flex-1 min-w-0">
        <h1 class="text-2xl font-medium mb-2">比戸 将平 <span class="text-gray-500 font-normal ml-2">Shohei Hido</span></h1>
        <p class="text-base md:text-lg text-gray-700 mb-4">
          <a href="https://www.daikin.co.jp/" target="_blank" rel="noopener">ダイキン工業株式会社</a> テクノロジー・イノベーションセンター 技師長（DX推進担当）
        </p>
        <SocialLinks class="mb-4" />
        <p class="text-sm font-medium text-gray-900 leading-snug mb-5 border-l-4 border-sky-300 pl-3">
          20年にわたって、先端AI技術の産業応用をリード。
        </p>
        <div class="space-y-3 text-sm leading-[1.85] text-gray-800">
          <p>
            現在、ダイキン工業株式会社 テクノロジー・イノベーションセンター（TIC）技師長として、生成AIをはじめとする先端AI技術の製造業応用、
            および全社的なデジタル変革・データ活用の推進、デジタル人材教育に従事。直近では設計開発生成AIと空調分野に特化したLLMの構築プロジェクトを牽引。
          </p>
          <p>
            2006年京都大学大学院情報学研究科修士修了（システム科学専攻）。日本IBM東京基礎研究所で機械学習技術の研究開発と顧客向けデータサイエンスプロジェクト従事した後、
            2012年に株式会社Preferred Infrastructureへ入社。
            2014年に設立された株式会社Preferred Networksに転籍し、2015年から米シリコンバレーへChief Research Officerとして出向。
            2018年に本社帰任後は研究開発担当VP、執行役員兼インダストリーソリューション担当VPとして先端研究・大企業との共同研究開発・新規事業立ち上げを牽引。
            2023年1月より現職。
          </p>
          <p>
            研究領域は時系列解析・異常検知・密度比推定・グラフマイニングなど。
            Chainer / CuPy / Jubatus などオープンソース機械学習フレームワークのプロジェクトにも貢献。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-16">
    <div class="flex items-baseline justify-between mb-5">
      <h2 class="text-xl font-medium">最近の活動</h2>
      <a href="/talks-and-media/" class="text-sm">すべて見る →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {recentTopItems.map((it) => (
        <TalkCard
          title={it.title}
          date={it.date}
          event={it.subtitle}
          tag={it.tag}
          links={it.links}
          thumbnail={it.thumbnail}
        />
      ))}
    </div>
  </section>

  <section class="mb-16">
    <div class="flex items-baseline justify-between mb-5">
      <h2 class="text-xl font-medium">最近の論文</h2>
      <a href="/publications/" class="text-sm">すべて見る →</a>
    </div>
    <ul class="border-t border-gray-100 max-w-4xl">
      {recentPublications.map((p) => (
        <PublicationItem
          title={p.data.title}
          date={p.data.date}
          venue={p.data.venue}
          authors={p.data.authors}
          tag="論文"
          thumbnail={p.data.thumbnail}
          links={p.data.links}
        />
      ))}
    </ul>
  </section>
</BaseLayout>
